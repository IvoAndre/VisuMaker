    "use_template": False,
    "template_path": "",
    "subject": "Seu Certificado",
    "attachment_name": "Certificado_{nome}.png",  # Nome do anexo (pode usar placeholders)
    "cc": [],  # Lista de emails para CC
    "bcc": []  # Lista de emails para BCC
